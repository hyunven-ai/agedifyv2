# ============================================================
# FRONTEND ENVIRONMENT VARIABLES
# Isi nilai-nilai ini di Vercel Dashboard → Settings → Environment Variables
# ============================================================

# URL Backend Railway (wajib diisi setelah backend deploy)
NEXT_PUBLIC_BACKEND_URL=https://your-backend.up.railway.app

# URL Site Vercel kamu
NEXT_PUBLIC_SITE_URL=https://your-app.vercel.app

# URL Internal untuk Next.js rewrites ke backend (sama dengan backend URL)
INTERNAL_BACKEND_URL=https://your-backend.up.railway.app
