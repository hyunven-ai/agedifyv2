# ============================================================
# BACKEND ENVIRONMENT VARIABLES
# Isi nilai-nilai ini di Railway Dashboard → Variables
# ============================================================

# MongoDB Atlas (wajib diisi)
MONGO_URL=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/?retryWrites=true&w=majority
DB_NAME=agedify_db

# JWT Secret (wajib diisi - buat string random yang panjang)
JWT_SECRET=ganti-dengan-string-random-yang-sangat-panjang-dan-aman

# CORS (isi dengan URL frontend Vercel kamu setelah deploy)
CORS_ORIGINS=https://your-app.vercel.app,https://www.your-domain.com

# Site URL (isi dengan URL backend Railway kamu setelah deploy)
SITE_URL=https://your-backend.up.railway.app

# ============================================================
# CLOUDINARY (untuk penyimpanan gambar permanen)
# Daftar gratis di https://cloudinary.com
# Dapatkan nilai-nilai ini dari: Cloudinary Dashboard → API Keys
# ============================================================
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret
